# Local runtime
CVM_DATABASE_URL=postgresql+psycopg://cvm:cvm@localhost:55432/cvm
CVM_BUILD_ID=local-dev
CVM_API_PORT=8010
CVM_USER_WEB_PORT=4200
CVM_OPS_WEB_PORT=4201
CVM_EVALS_WEB_PORT=4202
CVM_TEMPORAL_HOST=localhost:7233
CVM_TEMPORAL_TASK_QUEUE=cvm-agent-runs
CVM_TEMPORAL_NAMESPACE=default
CVM_TEMPORAL_VISIBILITY_BACKEND=opensearch
CVM_TEMPORAL_UI_BASE_URL=http://127.0.0.1:8080

# Agent runtime
# 本地运行时默认直接连真实 OpenAI；自动化测试与 CI 会显式覆盖为 deterministic profile
CVM_AGENT_PROFILE=live
CVM_AGENT_MODEL=gpt-5.4-mini
CVM_AGENT_MODEL_SEARCH_REFLECTOR=gpt-5.4
CVM_AGENT_THINKING=low
CVM_AGENT_THINKING_SEARCH_REFLECTOR=medium
CVM_AGENT_MODEL_TIMEOUT_SECONDS=30
CVM_AGENT_MIN_ROUNDS=3
CVM_AGENT_MAX_ROUNDS=5
CVM_AGENT_ROUND_FETCH_SCHEDULE=10,5,5
CVM_AGENT_FINAL_TOP_K=5
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Local self-hosted Langfuse
CVM_LANGFUSE_HOST=http://127.0.0.1:4202
CVM_LANGFUSE_BASE_URL=http://127.0.0.1:4202
# 必填：复制到 .env 后填写本地值；不要把真实值提交到仓库
CVM_LANGFUSE_PUBLIC_KEY=
CVM_LANGFUSE_SECRET_KEY=
CVM_LANGFUSE_ENVIRONMENT=local
CVM_LANGFUSE_DOCKER_HOST=http://web-evals:3000
CVM_LANGFUSE_INIT_ORG_ID=org-cvm-local
CVM_LANGFUSE_INIT_ORG_NAME="CVM Local"
CVM_LANGFUSE_INIT_PROJECT_ID=project-cvm-local
CVM_LANGFUSE_INIT_PROJECT_NAME="CVM Agent Local"
CVM_LANGFUSE_INIT_USER_EMAIL=admin@local.test
CVM_LANGFUSE_INIT_USER_NAME="Local Admin"
CVM_LANGFUSE_INIT_USER_PASSWORD=
CVM_LANGFUSE_NEXTAUTH_SECRET=
CVM_LANGFUSE_SALT=
# 必填：64 位 hex 字符串
CVM_LANGFUSE_ENCRYPTION_KEY=
CVM_LANGFUSE_POSTGRES_USER=langfuse
CVM_LANGFUSE_POSTGRES_PASSWORD=
CVM_LANGFUSE_POSTGRES_DB=langfuse
CVM_LANGFUSE_CLICKHOUSE_USER=clickhouse
CVM_LANGFUSE_CLICKHOUSE_PASSWORD=
CVM_LANGFUSE_MINIO_ROOT_USER=minio
CVM_LANGFUSE_MINIO_ROOT_PASSWORD=
CVM_LANGFUSE_REDIS_AUTH=
CVM_LANGFUSE_S3_BUCKET=langfuse

# Resume source
# 本地运行时默认直接连真实 CTS；自动化测试与 CI 会显式覆盖为 deterministic mock
CVM_RESUME_SOURCE_MODE=cts
CVM_CTS_BASE_URL=https://link.hewa.cn
CVM_CTS_TENANT_KEY=fill-me
CVM_CTS_TENANT_SECRET=fill-me
CVM_CTS_TIMEOUT_SECONDS=20
CVM_ALLOW_SENSITIVE_EXPORT=false
CVM_EXPORTS_DIR=var/exports
CVM_CORS_ORIGINS=http://localhost:4200,http://127.0.0.1:4200,http://localhost:4201,http://127.0.0.1:4201,http://localhost:4202,http://127.0.0.1:4202

# Local Docker infra
CVM_POSTGRES_USER=cvm
CVM_POSTGRES_PASSWORD=cvm
CVM_POSTGRES_DB=cvm
CVM_POSTGRES_PORT=55432
CVM_TEMPORAL_PORT=7233
CVM_TEMPORAL_UI_PORT=8080
CVM_OPENSEARCH_PORT=9200
CVM_OPENSEARCH_VERSION=2.19.1
CVM_TEMPORAL_ADMINTOOLS_VERSION=1.29
CVM_TEMPORAL_VISIBILITY_INDEX=temporal_visibility_v1_dev
