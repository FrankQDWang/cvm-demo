#!/bin/sh
set -eu

branch_checkout="${3:-0}"

if [ "$branch_checkout" != "1" ]; then
  exit 0
fi

if [ "${CVM_SINGLE_BRANCH_GUARD_ACTIVE:-0}" = "1" ]; then
  exit 0
fi

branch_name="$(git symbolic-ref --quiet --short HEAD 2>/dev/null || true)"

if [ -z "$branch_name" ] || [ "$branch_name" = "main" ]; then
  exit 0
fi

printf '%s\n' "single-branch mode: branch '$branch_name' is not allowed; switching back to 'main'." >&2
CVM_SINGLE_BRANCH_GUARD_ACTIVE=1 git switch --quiet main

if [ "$(git rev-parse "$branch_name")" = "$(git rev-parse main)" ]; then
  git branch -D "$branch_name" >/dev/null 2>&1 || true
  printf '%s\n' "single-branch mode: deleted temporary branch '$branch_name'." >&2
else
  printf '%s\n' "single-branch mode: branch '$branch_name' differs from main and was left in place; reconcile and delete it manually." >&2
fi
