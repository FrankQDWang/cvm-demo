{
  "name": "cvm-demo",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "codegen:ts": "openapi --input contracts/openapi/platform-api.openapi.yaml --output libs/ts/api-client-generated/src/generated --client fetch --useOptions --exportSchemas true",
    "lint:ts": "eslint --max-warnings=0 apps/web-user/src apps/web-ops/src apps/web-evals/src libs/ts/platform-api-client/src",
    "check:deps:ts": "depcruise --config .dependency-cruiser.cjs apps/web-user/src apps/web-ops/src apps/web-evals/src libs/ts/platform-api-client/src",
    "check:unused:ts": "knip --config knip.config.ts --workspace apps/web-user --workspace apps/web-ops --workspace apps/web-evals --workspace libs/ts/platform-api-client --no-config-hints"
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "angular-eslint": "^21.0.1",
    "dependency-cruiser": "^17.3.9",
    "eslint": "^9.37.0",
    "globals": "^16.4.0",
    "knip": "^6.0.4",
    "openapi-typescript-codegen": "^0.30.0",
    "tslib": "^2.8.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.1"
  }
}
